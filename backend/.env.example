# ===== 亚马逊赛训效率工具箱 - 环境变量配置 =====
# 复制此文件为 .env 并修改配置

# ===== 数据库配置 =====
# 数据库类型: "sqlite" (本地开发) 或 "mysql" (生产环境)
DB_TYPE=mysql

# MySQL 配置（生产环境必须）
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=amazon_toolbox

# ===== JWT 配置 =====
# JWT 密钥（生产环境必须修改为强密码！）
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production

# Token 过期时间（分钟），默认 24 小时
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===== Redis 配置（生产环境强烈推荐）=====
# Redis 用于缓存、Token 黑名单、分布式限流等
# 不配置则使用内存缓存（仅适合单机开发）
REDIS_URL=redis://localhost:6379/0

# ===== API 频率限制 =====
# 每分钟最大请求数
RATE_LIMIT_PER_MINUTE=60

# ===== CORS 配置 =====
# 允许的域名，多个用逗号分隔
CORS_ORIGINS=*

# ===== 管理员配置 =====
# 默认管理员密码（首次初始化时使用）
DEFAULT_ADMIN_PASSWORD=admin123

# ===== 日志配置 =====
# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 日志格式: 留空使用人类可读格式，设为 "json" 使用 JSON 格式（生产环境推荐）
# LOG_FORMAT=json

# ===== 调试模式 =====
# 生产环境必须设为 false（会暴露 Swagger 文档和调试信息）
DEBUG=false

# ===== AI 客服配置 =====
# AI 提供商: "qwen" (通义千问) 或 "openai"
AI_PROVIDER=qwen

# 通义千问 API Key
QWEN_API_KEY=your_qwen_api_key_here

# 通义千问对话模型
QWEN_MODEL=qwen3.7-plus

# 通义千问 Embedding 模型
QWEN_EMBEDDING_MODEL=text-embedding-v2

# ChromaDB 向量库数据目录
CHROMA_PERSIST_DIR=./chroma_db

# AI 客服最大重试次数
AI_CHAT_MAX_RETRIES=2

# AI 客服对话历史轮数
AI_CHAT_MAX_HISTORY=5
