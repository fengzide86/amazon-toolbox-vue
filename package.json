{
  "name": "amazon-toolbox",
  "version": "1.6.8",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --mode development",
    "build": "vite build --mode production",
    "preview": "vite preview",
    "electron:dev": "vite build --mode production && electron .",
    "electron:build": "vite build --mode production && set CSC_IDENTITY_AUTO_DISCOVERY=false && electron-builder --win nsis",
    "electron:preview": "electron .",
    "test": "vitest run",
    "test:run": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "build:verify": "npm run build && node scripts/verify-build.js"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@lucide/vue": "^1.21.0",
    "@sentry/vue": "^10.57.0",
    "chart.js": "^4.5.1",
    "electron-updater": "^6.8.3",
    "element-plus": "^2.14.2",
    "pinia": "^3.0.4",
    "vue": "^3.4.21",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^4.3.0",
    "web-vitals": "^5.3.0"
  },
  "devDependencies": {
    "@fullhuman/postcss-purgecss": "^8.0.0",
    "@playwright/test": "^1.61.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/coverage-v8": "^2.1.9",
    "@vue/test-utils": "^2.4.11",
    "autoprefixer": "^10.5.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.8.1",
    "happy-dom": "^20.10.2",
    "jsdom": "^29.1.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "terser": "^5.48.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^5.1.6",
    "vite-plugin-image-optimizer": "^2.0.3",
    "vite-plugin-imagemin": "^0.6.1",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^2.1.0"
  },
  "build": {
    "appId": "com.amazon.toolbox",
    "productName": "\u8de8\u5883\u7535\u5546\u8d5b\u8bad\u6548\u7387\u5de5\u5177\u7bb1",
    "directories": {
      "output": "release"
    },
    "extraFiles": [],
    "extraResources": [
      {
        "from": "electron/toolbox-backend.exe",
        "to": "toolbox-backend.exe"
      },
      {
        "from": "electron/start-backend.bat",
        "to": "start-backend.bat"
      }
    ],
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!electron/toolbox-backend.exe"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "\u4e9a\u9a6c\u900a\u5de5\u5177\u7bb1"
    },
    "publish": {
      "provider": "generic",
      "url": "http://8.130.113.104:8000/updates/",
      "channel": "latest"
    }
  }
}
